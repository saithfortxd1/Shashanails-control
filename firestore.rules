rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidClient(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'phone', 'ownerId', 'createdAt', 'updatedAt'])
        && data.firstName is string
        && data.lastName is string
        && data.phone is string
        && data.get('notes', '') is string
        && data.ownerId == request.auth.uid
        && data.createdAt is int
        && data.updatedAt is int;
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['clientId', 'clientName', 'date', 'service', 'price', 'locationType', 'status', 'ownerId', 'createdAt', 'updatedAt'])
        && data.clientId is string
        && data.clientName is string
        && data.date is int
        && data['service'] is string
        && (data.price is int || data.price is float)
        && (data.get('advancePayment', 0) is int || data.get('advancePayment', 0) is float)
        && data.get('paymentMethod', '') is string
        && (data.get('designImageUrl', null) == null || data.get('designImageUrl', '') is string)
        && (data.locationType == 'Presencial' || data.locationType == 'Domicilio')
        && data.get('address', '') is string
        && (data.status == 'scheduled' || data.status == 'completed' || data.status == 'cancelled' || data.status == 'no-show')
        && data.get('notified60', false) is bool
        && data.get('notified30', false) is bool
        && data.ownerId == request.auth.uid
        && data.createdAt is int
        && data.updatedAt is int;
    }

    function isValidDebt(data) {
      return data.keys().hasAll(['clientId', 'clientName', 'concept', 'amount', 'status', 'ownerId', 'createdAt'])
        && data.clientId is string
        && data.clientName is string
        && data.concept is string
        && (data.amount is int || data.amount is float)
        && (data.status == 'pending' || data.status == 'paid')
        && data.ownerId == request.auth.uid
        && data.createdAt is int
        && (data.get('paidAt', null) == null || data.get('paidAt', null) is int);
    }

    match /debts/{debtId} {
      allow read: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() 
        && isValidId(debtId)
        && isValidDebt(incoming())
        && exists(/databases/$(database)/documents/clients/$(incoming().clientId));
      allow update: if isSignedIn() 
        && isValidDebt(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().clientId == existing().clientId;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    match /clients/{clientId} {
      allow read: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() 
        && isValidId(clientId)
        && isValidClient(incoming());
      allow update: if isSignedIn() 
        && isValidClient(incoming())
        && incoming().ownerId == existing().ownerId;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() 
        && isValidId(appointmentId)
        && isValidAppointment(incoming())
        && exists(/databases/$(database)/documents/clients/$(incoming().clientId));
      allow update: if isSignedIn() 
        && isValidAppointment(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().clientId == existing().clientId;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    match /frequentServices/{serviceId} {
      allow read, list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid && incoming().name is string;
      allow update: if isSignedIn() && incoming().ownerId == existing().ownerId && incoming().name is string;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.token.email == 'saith.martinez7@gmail.com';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || request.auth.token.email == 'saith.martinez7@gmail.com');
    }
  }
}
